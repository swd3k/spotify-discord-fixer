{
  "name": "spotify-discord-fixer",
  "private": true,
  "version": "1.0.0",
  "description": "Неофициальная программа для управления записями hosts (домены Spotify -> прокси GeoHide), чтобы восстановить синхронизацию презенса Spotify в Discord.",
  "author": {
    "name": "swd3k",
    "email": "217737403+swd3k@users.noreply.github.com"
  },
  "license": "MIT",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node18 --format=cjs --external:electron --external:sudo-prompt --external:electron-updater --outdir=dist/electron",
    "copy:assets": "node -e \"const fs=require('fs');fs.copyFileSync('build/tray.png','dist/electron/tray.png');fs.copyFileSync('build/icon.png','dist/electron/icon.png');\"",
    "build": "npm run build:renderer && npm run build:electron && npm run copy:assets",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --x64 --arm64 --publish never",
    "dist:linux": "npm run build && electron-builder --linux --x64 --arm64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64 --publish never",
    "dist:all": "npm run build && electron-builder --win --linux --mac --x64 --arm64 --publish never",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"shared/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.6",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.3",
    "vitest": "^3.0.8"
  },
  "build": {
    "appId": "com.geohide.spotify-discord-hosts-fixer",
    "productName": "Spotify Discord Hosts Fixer",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Spotify-Discord-Hosts-Fixer-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Spotify-Discord-Hosts-Fixer-Setup-${version}-win-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Spotify-Discord-Hosts-Fixer-${version}-win-${arch}-portable.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "swd3k <217737403+swd3k@users.noreply.github.com>",
      "synopsis": "Восстановление Spotify-статуса в Discord через hosts",
      "executableName": "spotify-discord-hosts-fixer",
      "artifactName": "Spotify-Discord-Hosts-Fixer-${version}-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "artifactName": "Spotify-Discord-Hosts-Fixer-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "publish": {
      "provider": "github",
      "owner": "swd3k",
      "repo": "spotify-discord-fixer"
    }
  }
}
